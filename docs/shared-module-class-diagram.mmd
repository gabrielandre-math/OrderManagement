            +string EventType
        }
        class IAggregate {
            <<interface>>
            +IReadOnlyList DomainEvents
            +ClearDomainEvents() IDomainEvent[]
        }
        class IAggregate_T {
            <<interface>>
        }
        class Entity_T {
            <<abstract>>
            +T Id
            +DateTime CreatedAt
