    namespace Shared_Data_Interceptors {
        class AuditableEntityInterceptor {
            <<internal>>
            +SavingChanges(eventData, result) InterceptionResult
            +SavingChangesAsync(eventData, result, ct) ValueTask
            -UpdateEntities(DbContext context) void
        }
        class DispatchDomainEventsInterceptor {
            -IMediator mediator
            +SavingChanges(eventData, result) InterceptionResult
            +SavingChangesAsync(eventData, result, ct) ValueTask
            -DispatchDomainEvents(DbContext context) Task
        }
        class Extensions {
            <<static>>
            +HasChangedOwnedEntities(EntityEntry entry)$ bool
        }
    }

