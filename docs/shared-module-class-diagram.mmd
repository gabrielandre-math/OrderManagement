classDiagram
    direction TB

    %% ═══════════════════════════════════════════════════════
    %%  LAYER 1 — Shared.Contracts (zero dependencies)
    %% ═══════════════════════════════════════════════════════

    %% ── Results ──────────────────────────────────────────
    namespace Shared_Contracts_Results {
        class ErrorType {
            <<enumeration>>
            None = 0
            NotFound = 404
            Validation = 400
            BadRequest = 400
            Conflict = 409
            Forbidden = 403
            Unexpected = 500
        }
        class Error {
            <<sealed record>>
            +string Code
            +string Message
            +ErrorType Type
            +NotFound(code, message)$ Error
            +Validation(code, message)$ Error
            +BadRequest(code, message)$ Error
            +Conflict(code, message)$ Error
            +Forbidden(code, message)$ Error
            +Unexpected(code, message)$ Error
            -None$ Error
        }
        class Result {
            +bool IsSuccess
            +bool IsFailure
            +Error Error
            +Success()$ Result
            +Failure(Error)$ Result
            +Success~TValue~(TValue)$ Result~TValue~
            +Failure~TValue~(Error)$ Result~TValue~
        }
        class Result_T {
            +TValue Value
            +implicit operator Result_T(TValue)
        }
    }

    %% ── CQRS ────────────────────────────────────────────
    namespace Shared_Contracts_CQRS {
        class ICommand {
            <<interface>>
        }
        class ICommand_TResponse {
            <<interface>>
        }
        class ICommandHandler_TCommand {
            <<interface>>
        }
        class ICommandHandler_TCommand_TResponse {
            <<interface>>
        }
        class IQuery_T {
            <<interface>>
        }
        class IQueryHandler_TQuery_TResponse {
            <<interface>>
        }
    }

    %% ═══════════════════════════════════════════════════════
    %%  LAYER 2 — Shared (depends on Shared.Contracts)
    %% ═══════════════════════════════════════════════════════

    %% ── DDD Building Blocks ─────────────────────────────
    namespace Shared_DDD {
        class IEntity {
            <<interface>>
            +DateTime? CreatedAt
            +string? CreatedBy
            +DateTime? LastModified
            +string? LastModifiedBy
        }
        class IEntity_T {
            <<interface>>
            +T Id
        }
        class IDomainEvent {
            <<interface>>
            +Guid EventId
            +DateTime OccuredOn
            +string EventType
        }
        class IAggregate {
            <<interface>>
            +IReadOnlyList~IDomainEvent~ DomainEvents
            +ClearDomainEvents() IDomainEvent[]
        }
        class IAggregate_T {
            <<interface>>
        }
        class Entity_T {
            <<abstract>>
            +T Id
            +DateTime? CreatedAt
            +string? CreatedBy
            +DateTime? LastModified
            +string? LastModifiedBy
        }
        class Aggregate_TId {
            <<abstract>>
            -List~IDomainEvent~ _domainEvents
            +IReadOnlyList~IDomainEvent~ DomainEvents
            +AddDomainEvent(IDomainEvent) void
            +ClearDomainEvents() IDomainEvent[]
        }
    }

    %% ── EF Core Interceptors ────────────────────────────
    namespace Shared_Data_Interceptors {
        class AuditableEntityInterceptor {
            <<internal>>
            -IHttpContextAccessor httpContextAccessor
            +SavingChanges() InterceptionResult
            +SavingChangesAsync() ValueTask
            -UpdateEntities(DbContext) void
        }
        class DispatchDomainEventsInterceptor {
            -IMediator mediator
            +SavingChanges() InterceptionResult
            +SavingChangesAsync() ValueTask
            -DispatchDomainEvents(DbContext) Task
        }
        class Extensions {
            <<static>>
            +HasChangedOwnedEntities(EntityEntry)$ bool
        }
    }

    %% ── Data Seed ───────────────────────────────────────
    namespace Shared_Data_Seed {
        class IDataSeeder {
            <<interface>>
            +SeedAllAsync() Task
        }
    }

    %% ── MediatR Pipeline Behaviors ─────────────────────
    namespace Shared_Behaviors {
        class ValidationBehavior_TRequest_TResponse {
            -IEnumerable~IValidator~ validators
            +Handle(TRequest, next, ct) Task~TResponse~
        }
        class LoggingBehavior_TRequest_TResponse {
            -ILogger logger
            +Handle(TRequest, next, ct) Task~TResponse~
        }
    }

    %% ── Exception Handler (Safety Net) ─────────────────
    namespace Shared_Exceptions_Handler {
        class CustomExceptionHandler {
            -ILogger logger
            -IStringLocalizer~SharedMessages~ localizer
            +TryHandleAsync(HttpContext, Exception, ct) ValueTask~bool~
        }
    }

    %% ── i18n Resources ─────────────────────────────────
    namespace Shared_Resources {
        class SharedMessages {
            <<marker class>>
        }
    }

    %% ── Extensions ──────────────────────────────────────
    namespace Shared_Extensions {
        class ResultExtensions {
            <<static>>
            +ToProblemResult~T~(Result~T~)$ IResult
            +ToProblemResult(Result)$ IResult
            +ToCreatedResult~T~(Result~T~, uri)$ IResult
            -ToProblemDetails(Error)$ IResult
        }
        class CarterExtensions {
            <<static>>
            +AddCarterWithAssemblies(IServiceCollection, Assembly[])$ IServiceCollection
        }
        class MediatRExtensions {
            <<static>>
            +AddMediatRWithAssemblies(IServiceCollection, Assembly[])$ IServiceCollection
        }
    }

    %% ── Pagination ──────────────────────────────────────
    namespace Shared_Pagination {
