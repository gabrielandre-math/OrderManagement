    %% ═══════════════════════════════════════════════════
    %%  DDD Inheritance / Realization
    %% ═══════════════════════════════════════════════════
    IEntity_T --|> IEntity : extends
    IAggregate --|> IEntity : extends
    IAggregate_T --|> IAggregate : extends
    IAggregate_T --|> IEntity_T : extends
    Entity_T ..|> IEntity_T : implements
    Aggregate_TId --|> Entity_T : extends
    Aggregate_TId ..|> IAggregate_T : implements

    %% ═══════════════════════════════════════════════════
    %%  DDD Composition / Aggregation
    %% ═══════════════════════════════════════════════════
    Aggregate_TId *-- IDomainEvent : _domainEvents 0..*
    IAggregate o-- IDomainEvent : DomainEvents 0..*

    %% ═══════════════════════════════════════════════════
    %%  MediatR Realization
    %% ═══════════════════════════════════════════════════
    IDomainEvent ..|> INotification : MediatR
    ICommand --|> ICommand_TResponse : extends Unit
    ICommand_TResponse ..|> IRequest : MediatR
    ICommandHandler_TCommand --|> ICommandHandler_TCommand_TResponse : extends Unit
    ICommandHandler_TCommand_TResponse ..|> IRequestHandler : MediatR
    IQuery_T ..|> IRequest : MediatR
    IQueryHandler_TQuery_TResponse ..|> IRequestHandler : MediatR

    %% ═══════════════════════════════════════════════════
    %%  Behaviors
    %% ═══════════════════════════════════════════════════
    ValidationBehavior_TRequest_TResponse ..|> IPipelineBehavior : MediatR
    LoggingBehavior_TRequest_TResponse ..|> IPipelineBehavior : MediatR
    ValidationBehavior_TRequest_TResponse ..> ICommand_TResponse : bind TRequest
    ValidationBehavior_TRequest_TResponse ..> IValidator : use
    LoggingBehavior_TRequest_TResponse ..> IMediator : use

    %% ═══════════════════════════════════════════════════
    %%  Interceptors to DDD
    %% ═══════════════════════════════════════════════════
    AuditableEntityInterceptor --|> SaveChangesInterceptor : EF Core
    AuditableEntityInterceptor ..> IEntity : tracks changes
    DispatchDomainEventsInterceptor --|> SaveChangesInterceptor : EF Core
    DispatchDomainEventsInterceptor ..> IAggregate : dispatches events
    DispatchDomainEventsInterceptor ..> IMediator : use

    %% ═══════════════════════════════════════════════════
    %%  Exceptions
    %% ═══════════════════════════════════════════════════
    BadRequestException --|> Exception : extends
    InternalServerException --|> Exception : extends
    NotFoundException --|> Exception : extends

    %% ═══════════════════════════════════════════════════
    %%  Exception Handler
    %% ═══════════════════════════════════════════════════
    CustomExceptionHandler ..|> IExceptionHandler : ASP.NET Core
    CustomExceptionHandler ..> BadRequestException : handles
    CustomExceptionHandler ..> InternalServerException : handles
    CustomExceptionHandler ..> NotFoundException : handles

    %% ═══════════════════════════════════════════════════
    %%  Extensions to Behaviors
    %% ═══════════════════════════════════════════════════
    MediatRExtensions ..> ValidationBehavior_TRequest_TResponse : register
    MediatRExtensions ..> LoggingBehavior_TRequest_TResponse : register

    %% ═══════════════════════════════════════════════════
    %%  Messaging
    %% ═══════════════════════════════════════════════════
    BasketCheckoutIntegrationEvent --|> IntegrationEvent : extends
    ProductPriceChangedIntegrationEvent --|> IntegrationEvent : extends
