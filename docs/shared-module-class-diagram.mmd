    namespace Shared_DDD {
        class IEntity {
            <<interface>>
            +DateTime CreatedAt
            +string CreatedBy
            +DateTime LastModified
            +string LastModifiedBy
        }
        class IEntity_T {
            <<interface>>
            +T Id
        }
        class IDomainEvent {
            <<interface>>
            +Guid EventId
